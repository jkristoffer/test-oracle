{
  "name": "test-oracle",
  "version": "0.5.0",
  "private": false,
  "description": "Deterministic test-orchestration CLI for impacted-test execution",
  "license": "MIT",
  "author": "Kris (Big Shine Singapore Pte Ltd)",
  "repository": {
    "type": "git",
    "url": "https://github.com/kristoffersanio/test-oracle.git"
  },
  "keywords": [
    "test-oracle",
    "ci",
    "impact-testing",
    "cli"
  ],
  "bin": {
    "test-oracle": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test test/**/*.test.js"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
